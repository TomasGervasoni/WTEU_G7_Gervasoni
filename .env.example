# ─── Variables de entorno — WTEU_G7_Gervasoni ───────────────────────────────
# Copiá este archivo a .env y completá los valores reales.
# .env NUNCA se commitea (está en .gitignore).

# ── Node ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL (Docker local) ────────────────────────────────────────────────
# DB_HOST es el nombre del servicio en docker-compose.yml → 'db'
# En Railway usá DATABASE_URL en su lugar (ver más abajo).
DB_HOST=db
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=wteu_db
# Activar SSL solo en Railway/producción (true | false)
DB_SSL=false

# ── Railway / Heroku (producción) ────────────────────────────────────────────
# Si el provider entrega una connection string completa, definí esta variable
# y dejá las DB_* vacías; config/db.js prioriza DATABASE_URL.
DATABASE_URL=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens. Usá una cadena larga y aleatoria.
JWT_SECRET=
# Duración del token (ej: '7d', '24h', '60m')
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────────
# Lista de orígenes permitidos separados por coma (sin espacios).
# Incluir el origen de GitHub Pages cuando se publique.
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# ── MercadoPago (Módulo Pagos — CU-021) ─────────────────────────────────────
# Usá las credenciales de TEST hasta la presentación del TP.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
# URL base del backend para los callbacks de MercadoPago
MP_BACK_URL_BASE=http://localhost:3000
